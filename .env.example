# Database Configuration
DATABASE_URL=sqlite:///./lumen.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/lumen_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-here

# API Configuration
DEBUG=false
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# COPPA & Compliance Settings
MIN_AGE=13
REQUIRE_PARENTAL_CONSENT=true
PARENT_EMAIL_VERIFICATION=true

# Email (for parental consent notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ADMIN_EMAIL=admin@lumen-ai.edu

# CrewAI Configuration
CREWAI_MODEL=gpt-4
CREWAI_TEMPERATURE=0.7

# Anthropic API (alternative to OpenAI)
ANTHROPIC_API_KEY=your-api-key-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/lumen.log

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Session Configuration
SESSION_EXPIRY_HOURS=24
TOKEN_EXPIRY_MINUTES=480

# Optional: Third-party integrations
GOOGLE_CLASSROOM_API_KEY=
CANVAS_API_KEY=
SLACK_WEBHOOK_URL=
